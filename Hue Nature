<title>Hue Nature</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&family=Playfair+Display&display=swap" rel="stylesheet">

<style>
:root {
  --green: #7aa98f;
  --sage: #dff1e3;
  --beige: #fff8f2;
  --blush: #f7dede;
  --dark: #2f4f3e;
}

* { box-sizing: border-box; }

body {
  margin: 0;
  font-family: 'Poppins', sans-serif;
  background: linear-gradient(var(--beige), #ffffff);
  color: var(--dark);
}

header {
  text-align: center;
  padding: 16px 12px;
  background: linear-gradient(var(--sage), var(--blush));
}

header img { width: 80px; max-width: 30vw; height: auto; }

h1 { font-family: 'Playfair Display', serif; margin: 8px 0; font-size: clamp(22px, 4vw, 32px); }

nav {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 10px 14px;
  margin-top: 8px;
}

nav a {
  text-decoration: none;
  color: var(--dark);
  font-weight: 500;
  font-size: 14px;
}

.container {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 16px;
}

section {
  padding: 40px 0;
}

.card {
  background: white;
  border-radius: 20px;
  padding: clamp(18px, 3vw, 28px);
  margin-bottom: 20px;
  box-shadow: 0 8px 22px rgba(0,0,0,0.06);
}

h2 { font-size: clamp(20px, 3.5vw, 26px); margin-top: 0; }
h3 { font-size: clamp(16px, 3vw, 20px); }
p, li { font-size: clamp(14px, 2.8vw, 16px); line-height: 1.6; }

.grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 16px;
}

.founder {
  display: grid;
  grid-template-columns: 260px 1fr;
  gap: 20px;
  align-items: center;
}

.founder img {
  width: 100%;
  max-width: 260px;
  border-radius: 50%;
  display: block;
  margin: 0 auto;
}

.button {
  display: inline-block;
  margin-top: 10px;
  padding: 10px 16px;
  border-radius: 20px;
  background: var(--green);
  color: #fff;
  text-decoration: none;
  font-size: 14px;
}

footer {
  text-align: center;
  padding: 16px;
  background: linear-gradient(var(--blush), var(--sage));
  font-size: 14px;
}

/* Mobile adjustments */
@media (max-width: 768px) {
  .founder {
    grid-template-columns: 1fr;
    text-align: center;
  }
  nav a { font-size: 13px; }
}

/* Very small devices */
@media (max-width: 420px) {
  header img { width: 64px; }
  nav { gap: 8px 10px; }
}
</style>
</head>

